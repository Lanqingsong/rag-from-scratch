# ── 主力 LLM（DeepSeek）─────────────────────────────────────
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com

# ── Embedding + Reranker（阿里云千问）────────────────────────
# 获取地址：https://dashscope.console.aliyun.com/
QIANWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
QIANWEN_API_BASE=https://dashscope.aliyuncs.com/api/v1

# ── 网络搜索（SearXNG 本地服务）─────────────────────────────
# 启动方式：docker run -d --name searxng -p 8080:8080 searxng/searxng
# 不配置此项也可正常使用，仅禁用网络搜索功能
SEARXNG_URL=http://localhost:8080
SEARXNG_LANGUAGE=zh-CN

# ── LangSmith 可观测（可选）──────────────────────────────────
# 获取地址：https://smith.langchain.com/
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_xxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=zhishiku
